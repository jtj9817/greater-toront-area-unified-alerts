APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For MySQL manual tests, use the dedicated .env.testing (DB_DATABASE=gta_alerts_testing).
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Set BROADCAST_CONNECTION to "reverb" or "pusher" to enable real-time delivery.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Allows ingestion jobs to proceed when upstream feeds return zero records.
# Keep `false` in production to avoid mass deactivation on upstream failures.
ALLOW_EMPTY_FEEDS=false

# Optional comma-separated allowlist for Scene Intel manual note creation.
# Empty means any authenticated + verified user may create manual notes.
SCENE_INTEL_MANUAL_ENTRY_ALLOWED_EMAILS=

CACHE_STORE=database
# Use a non-database store for unique scheduled-fetch locks.
# For shared multi-node environments, prefer redis.
QUEUE_UNIQUE_LOCK_STORE=file

# Debug: log when jobs are enqueued (helps diagnose duplicate schedulers / runaway dispatch).
# Writes to storage/logs/queue_enqueues.log
QUEUE_DEBUG_ENQUEUES=false
# Comma-separated matchers; exact class name or substring. Use "*" to log all enqueues.
QUEUE_DEBUG_ENQUEUES_MATCH=App\\Jobs\\FetchFireIncidentsJob,App\\Jobs\\FetchPoliceCallsJob,App\\Jobs\\FetchTransitAlertsJob,App\\Jobs\\FetchGoTransitAlertsJob,App\\Jobs\\GenerateDailyDigestJob
# Include a compact stack trace for each enqueue (noisy).
QUEUE_DEBUG_ENQUEUES_STACK=false
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
